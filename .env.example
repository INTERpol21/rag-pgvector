# --- API ---
PORT=8081
# Comma-separated bearer keys accepted on /v1/*:
RAG_API_KEYS=demo-key

# --- Vector store: memory (default, zero deps) | pgvector ---
STORE_BACKEND=memory
DATABASE_URL=postgresql://rag:rag@localhost:5432/rag

# --- Embeddings: hash (default, offline) | semantic (offline, synonym-aware) | openai ---
EMBEDDINGS_BACKEND=hash
# The store sizes its schema from this — for openai it MUST match the model's
# output width (1536 for text-embedding-3-small, 3072 for -large):
EMBEDDING_DIM=256
# For EMBEDDINGS_BACKEND=openai:
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# --- Retrieval ---
# hybrid (default: vector + keyword fused with RRF) | vector (cosine only)
SEARCH_MODE=hybrid
# none (default) | mock (deterministic reorder) | llm (cross-encoder through the LLM backend)
RERANKER=none

# --- LLM synthesis: mock (default, offline) | grounded (offline, abstains without evidence) | openai ---
LLM_BACKEND=mock
# Point at the sibling llm-gateway (or any OpenAI-compatible endpoint):
LLM_BASE_URL=http://localhost:8080/v1
LLM_API_KEY=demo-key
LLM_MODEL=mock-small

# --- Evals ---
# JUDGE_BACKEND=mock (deterministic, offline) | openai (through LLM_BASE_URL)
JUDGE_BACKEND=mock
